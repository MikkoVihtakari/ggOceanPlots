Package: ggOceanPlots
Type: Package
Title: Helpers for the Analysis of Oceanographic Data
Version: 0.2.0
Date: 2026-06-18
Authors@R: c(person("Mikko", "Vihtakari", email = "mikko.vihtakari@hi.no",
